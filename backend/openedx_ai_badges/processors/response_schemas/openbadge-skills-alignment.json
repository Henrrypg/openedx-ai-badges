{
  "type": "json_schema",
  "json_schema": {
    "name": "BadgeSkillsAlignment",
    "strict": true,
    "schema": {
      "type": "object",
      "properties": {
        "skills": {
          "type": "array",
          "description": "A list of skills aligned with this achievement.",
          "items": {
            "type": "object",
            "properties": {
              "type": {
                "type": "string",
                "const": "Alignment",
                "description": "Must always be 'Alignment'."
              },
              "targetType": {
                "type": "string",
                "description": "The type of the target, e.g., 'ESCO:Skill' or 'CF:Skill'."
              },
              "targetName": {
                "type": "string",
                "description": "The name of the specific skill (e.g., 'Computer Programming')."
              },
              "targetDescription": {
                "type": "string",
                "description": "A detailed description of what the skill entails."
              },
              "targetUrl": {
                "type": "string",
                "description": "The URL pointing to the official skill definition (e.g., ESCO portal)."
              }
            },
            "required": [
              "type",
              "targetType",
              "targetName",
              "targetDescription",
              "targetUrl"
            ],
            "additionalProperties": false
          }
        }
      },
      "required": [
        "skills"
      ],
      "additionalProperties": false
    }
  }
}
